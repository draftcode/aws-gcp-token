amends "package://github.com/jdx/hk/releases/download/v1.43.0/hk@1.43.0#/Config.pkl"
import "package://github.com/jdx/hk/releases/download/v1.43.0/hk@1.43.0#/Builtins.pkl"

local allSteps: Mapping<String, Step> = new {
  ["go-fumpt"] = Builtins.go_fumpt
  ["gomod-tidy"] = Builtins.gomod_tidy
  ["golangci-lint"] = Builtins.golangci_lint
  ["go-licenses"] = new Step {
    glob = List("go.mod", "go.sum", "**/*.go")
    workspace_indicator = "go.mod"
    check = "go-licenses check ./..."
  }
  ["mise-fmt"] = new Step {
    glob = List("mise.toml", ".mise.toml")
    check = "mise fmt --check"
    fix = "mise fmt"
  }
  ["pkl"] = Builtins.pkl_format
  ["typos"] = Builtins.typos
  ["actionlint"] = Builtins.actionlint
  ["zizmor"] = Builtins.zizmor
  ["newlines"] = Builtins.newlines
  ["trailing-whitespace"] = Builtins.trailing_whitespace
  ["mixed-line-ending"] = Builtins.mixed_line_ending
  ["check-merge-conflict"] = Builtins.check_merge_conflict
}

hooks {
  ["pre-commit"] { steps = allSteps }
  ["pre-push"] { steps = allSteps }
  ["check"] { steps = allSteps }
  ["fix"] { steps = allSteps }
}
